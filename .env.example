# ============================================================
# FICHIER : .env.example
# Copier ce fichier en .env et remplir vos valeurs
# NE JAMAIS commiter le fichier .env dans git
# ============================================================

# --- Backend FastAPI ---
# URL de base de l'API backend (sans slash final)
# Utiliser cette variable dans tout le frontend React via import.meta.env.VITE_API_URL
VITE_API_URL=http://localhost:8000

# --- LLM : Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434

# Clé API pour modèles cloud proxifiés via Ollama (optionnel)
OLLAMA_API_KEY=

# Nom du modèle cloud configuré dans Ollama (optionnel)
OLLAMA_CLOUD_MODEL=glm-5:cloud

# --- LLM : Google Gemini (fallback si Ollama inaccessible) ---
GOOGLE_API_KEY=

# --- Notifications email (optionnel) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
